{
  "name": "ai-agent-switch",
  "version": "0.1.2",
  "description": "AI Agent Switch CLI/TUI control plane for switching AI coding agent providers and models.",
  "type": "module",
  "bin": {
    "ai-agent-switch": "./bin/ai-agent-switch.js",
    "as": "./bin/as.js"
  },
  "scripts": {
    "dev": "bun run src/cli/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/cli/main.ts --target=bun --outfile=dist/ai-agent-switch.js && cp dist/ai-agent-switch.js dist/as.js",
    "npm:build-package": "bun run scripts/build-npm-package.ts",
    "clean": "rm -rf dist",
    "check": "bun test && bun run typecheck && bun run build"
  },
  "files": [
    "bin",
    "README_CN.md"
  ],
  "optionalDependencies": {
    "ai-agent-switch-linux-x64": "0.1.2",
    "ai-agent-switch-darwin-arm64": "0.1.2",
    "ai-agent-switch-darwin-x64": "0.1.2",
    "ai-agent-switch-windows-x64": "0.1.2"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.4.2",
    "yaml": "^2.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "typescript": "^6.0.3"
  }
}
